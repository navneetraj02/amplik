{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome (Dev Server)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}/src",
            "sourceMapPathOverrides": {
                "webpack:///src/*": "${webRoot}/*"
            },
            "preLaunchTask": "npm: dev"
        }
    ]
}